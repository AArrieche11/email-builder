# Slack Bot User OAuth Token de GENAIBOT (xoxb-...)
# Obtenerlo en: https://api.slack.com/apps -> OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing Secret de la app GENAIBOT
# Obtenerlo en: https://api.slack.com/apps -> Basic Information -> App Credentials
SLACK_SIGNING_SECRET=your-signing-secret

# Secreto para firmar enlaces magicos y cookies de sesion (min. 32 caracteres aleatorios)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SLACK_MAGIC_LINK_SECRET=change-me-to-a-long-random-secret

# URL publica de la app (enlaces magicos y Event Subscriptions)
# En desarrollo local con Slack: usar ngrok -> https://xxxx.ngrok-free.app
NEXT_PUBLIC_APP_URL=asdf
