# Slack Bot User OAuth Token (xoxb-...)
# Obtenerlo en: https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing Secret de la app de Slack
# Obtenerlo en: https://api.slack.com/apps → Basic Information → App Credentials
SLACK_SIGNING_SECRET=your-signing-secret

# ID del canal de Slack donde se crearán los hilos de soporte (ej: C0123456789)
# El bot debe estar invitado a este canal con permisos chat:write y channels:history
SLACK_SUPPORT_CHANNEL_ID=C0123456789

# URL pública de la app (necesaria para configurar Event Subscriptions en Slack)
# En desarrollo local, usar ngrok o similar: https://xxxx.ngrok.io
NEXT_PUBLIC_APP_URL=http://localhost:3000
